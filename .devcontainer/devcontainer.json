// For format details, see https://aka.ms/devcontainer.json. For config options, see the
// README at: https://github.com/rocker-org/devcontainer-templates/tree/main/src/r-ver
{
  "name": "${localWorkspaceFolderBasename}",
  "image": "ghcr.io/rocker-org/devcontainer/r-ver:4.5",
  "features": {
    "ghcr.io/rocker-org/devcontainer-features/r-history:0": {},
    "ghcr.io/rocker-org/devcontainer-features/renv-cache:latest": {},
    "ghcr.io/rocker-org/devcontainer-features/quarto-cli:latest": {}
  },
  "postCreateCommand": "R -q -e 'renv::install()'",
  "customizations": {
    "vscode": {
      "extensions": [
        "posit.air-vscode"
      ]
    }
  }
}
